<?php
/** @var \Vendor\FitmentSearch\Block\Search\Form $block */
declare(strict_types=1);

$selectedVehicle = $block->getSelectedVehicle();
$makesUrl        = $block->getAjaxUrl('getMakes');
$modelsUrl       = $block->getAjaxUrl('getModels');
$yearsUrl        = $block->getAjaxUrl('getYears');
$searchUrl       = $block->getSearchUrl();
$clearUrl        = $block->getClearUrl();
?>
<link rel="stylesheet" type="text/css"
      href="<?= $block->escapeHtmlAttr($block->getViewFileUrl('Vendor_FitmentSearch::css/fitment-search.css')) ?>"/>

<?php if ($selectedVehicle): ?>
    <!-- ================================================================
         Vehicle already selected → show pill with clear button
         ================================================================ -->
    <div class="fitment-widget">
        <div class="fitment-widget-pill">
            &#128663;&nbsp;
            <span>
                <?= $block->escapeHtml(
                    $selectedVehicle['make'] . ' '
                    . $selectedVehicle['model'] . ' '
                    . $selectedVehicle['year']
                ) ?>
            </span>
            <span class="clear-pill"
                  id="fitment-widget-clear"
                  data-clear-url="<?= $block->escapeHtmlAttr($clearUrl) ?>"
                  title="<?= $block->escapeHtmlAttr(__('ล้างรถที่เลือก')) ?>"
                  role="button"
                  tabindex="0">
                &times;
            </span>
        </div>
    </div>

<?php else: ?>
    <!-- ================================================================
         No vehicle selected → show cascading selects
         ================================================================ -->
    <div class="fitment-widget">
        <select id="fitment-widget-make" name="make" class="fitment-select"
                aria-label="<?= $block->escapeHtmlAttr(__('ยี่ห้อรถ')) ?>">
            <option value="" disabled selected><?= $block->escapeHtml(__('-- ยี่ห้อ --')) ?></option>
        </select>

        <select id="fitment-widget-model" name="model" class="fitment-select" disabled
                aria-label="<?= $block->escapeHtmlAttr(__('รุ่นรถ')) ?>">
            <option value="" disabled selected><?= $block->escapeHtml(__('-- รุ่น --')) ?></option>
        </select>

        <select id="fitment-widget-year" name="year" class="fitment-select" disabled
                aria-label="<?= $block->escapeHtmlAttr(__('ปีรถ')) ?>">
            <option value="" disabled selected><?= $block->escapeHtml(__('-- ปี --')) ?></option>
        </select>

        <button type="button"
                id="fitment-widget-search-btn"
                class="fitment-search-btn"
                disabled
                aria-label="<?= $block->escapeHtmlAttr(__('ค้นหาอะไหล่')) ?>">
            &#128269; <?= $block->escapeHtml(__('ค้นหา')) ?>
        </button>
    </div>

<?php endif; ?>

<script type="text/javascript">
    require(['fitmentSearch'], function (fs) {
        fs.initWidget({
            makesUrl:  '<?= $block->escapeJs($makesUrl) ?>',
            modelsUrl: '<?= $block->escapeJs($modelsUrl) ?>',
            yearsUrl:  '<?= $block->escapeJs($yearsUrl) ?>',
            searchUrl: '<?= $block->escapeJs($searchUrl) ?>',
            clearUrl:  '<?= $block->escapeJs($clearUrl) ?>'
        });
    });
</script>
