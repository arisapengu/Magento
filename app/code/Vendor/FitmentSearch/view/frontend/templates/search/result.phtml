</div><!-- /.fitment-results-page -->

<script type="text/javascript">
    require(['fitmentSearch'], function (fs) {
        fs.initWidget({
            makesUrl:  '<?= $block->escapeJs($makesUrl) ?>',
            modelsUrl: '<?= $block->escapeJs($modelsUrl) ?>',
            yearsUrl:  '<?= $block->escapeJs($yearsUrl) ?>',
            searchUrl: '<?= $block->escapeJs($searchUrl) ?>',
            clearUrl:  '<?= $block->escapeJs($clearUrl) ?>'
        });
    });
</script>
