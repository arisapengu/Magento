<?php
/** @var \Vendor\FitmentSearch\Block\Search\Result $block */
declare(strict_types=1);

$products      = $block->getProducts();
$vehicleLabel  = $block->getVehicleLabel();
$productCount  = $products ? $products->getSize() : 0;
$makesUrl      = $block->getAjaxUrl('getMakes');
$modelsUrl     = $block->getAjaxUrl('getModels');
$yearsUrl      = $block->getAjaxUrl('getYears');
$searchUrl     = $block->getSearchUrl();
$clearUrl      = $block->getClearUrl();
$formUrl       = $block->getFormUrl();
$make          = (string)$block->getData('make');
$model         = (string)$block->getData('model');
$year          = (string)$block->getData('year');
?>
<link rel="stylesheet" type="text/css"
      href="<?= $block->escapeHtmlAttr($block->getViewFileUrl('Vendor_FitmentSearch::css/fitment-search.css')) ?>"/>

<div class="fitment-results-page">

    <!-- ====================================================
         Sidebar
         ==================================================== -->
    <aside class="fitment-sidebar">

        <!-- Current vehicle card -->
        <div class="fitment-vehicle-card">
            <h3><?= $block->escapeHtml(__('รถของคุณ')) ?></h3>
            <div class="vehicle-name"><?= $block->escapeHtml($vehicleLabel) ?></div>
        </div>

        <a href="<?= $block->escapeHtmlAttr($formUrl) ?>" class="fitment-change-btn">
            <?= $block->escapeHtml(__('เปลี่ยนรุ่นรถ')) ?>
        </a>

    </aside>

    <!-- ====================================================
         Main content area
         ==================================================== -->
    <main class="fitment-results-main">

        <div class="fitment-results-header">
            <h1>
                <?= $block->escapeHtml(__('อะไหล่สำหรับ')) ?>
                <?= $block->escapeHtml($vehicleLabel) ?>
            </h1>
            <div class="count">
                <?= $block->escapeHtml(__('พบ')) ?>
                <?= (int)$productCount ?>
                <?= $block->escapeHtml(__('รายการ')) ?>
            </div>
        </div>

        <div class="fitment-product-grid">

            <?php if ($products && $productCount > 0): ?>
                <?php foreach ($products as $product): ?>
                    <div class="fitment-product-card">
                        <a href="<?= $block->escapeHtmlAttr($block->getProductUrl($product)) ?>">
                            <img class="product-image"
                                 src="<?= $block->escapeHtmlAttr($block->getProductImageUrl($product)) ?>"
                                 alt="<?= $block->escapeHtmlAttr($product->getName()) ?>"
                                 loading="lazy"/>
                        </a>
                        <div class="product-info">
                            <div class="product-name">
                                <?= $block->escapeHtml($product->getName()) ?>
                            </div>
                            <div class="product-price">
                                <?= /* @noEscape */ $block->getFormattedPrice((float)$product->getPrice()) ?>
                            </div>
                            <a class="product-link"
                               href="<?= $block->escapeHtmlAttr($block->getProductUrl($product)) ?>">
                                <?= $block->escapeHtml(__('ดูรายละเอียด')) ?>
                            </a>
                        </div>
                    </div>
                <?php endforeach; ?>
            <?php else: ?>
                <div class="fitment-empty-state">
                    <div class="empty-icon">&#128663;</div>
                    <h3><?= $block->escapeHtml(__('ไม่พบอะไหล่สำหรับรถรุ่นนี้')) ?></h3>
                    <p><?= $block->escapeHtml(__('ลองเปลี่ยนรุ่นรถหรือติดต่อเรา')) ?></p>
                    <a href="<?= $block->escapeHtmlAttr($formUrl) ?>" class="retry-btn">
                        <?= $block->escapeHtml(__('เลือกรถรุ่นใหม่')) ?>
                    </a>
                </div>
            <?php endif; ?>

        </div><!-- /.fitment-product-grid -->

    </main>

</div><!-- /.fitment-results-page -->

