<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">vendor_vehicle_form.vendor_vehicle_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Vehicle Information</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>

    <settings>
        <buttons>
            <button name="back">
                <url path="*/*/index"/>
                <class>back</class>
                <label translate="true">Back</label>
            </button>
            <button name="save_and_continue"
                    class="Vendor\Vehicle\Block\Adminhtml\Vehicle\Edit\Button\SaveAndContinue"/>
            <button name="save">
                <url path="*/*/save"/>
                <class>save primary</class>
                <label translate="true">Save Vehicle</label>
            </button>
        </buttons>
        <namespace>vendor_vehicle_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>vendor_vehicle_form.vendor_vehicle_form_data_source</dep>
        </deps>
    </settings>

    <dataSource name="vendor_vehicle_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="*/*/save"/>
        </settings>
        <dataProvider class="Vendor\Vehicle\Model\Vehicle\DataProvider"
                      name="vendor_vehicle_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="general">
        <settings>
            <label translate="true">Vehicle Details</label>
        </settings>

        <field name="id" formElement="input">
            <settings>
                <dataType>text</dataType>
                <visible>false</visible>
            </settings>
        </field>

        <field name="make" sortOrder="10" formElement="input">
            <settings>
                <label translate="true">Make</label>
                <dataType>text</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="max_text_length" xsi:type="number">100</rule>
                </validation>
            </settings>
        </field>

        <field name="model" sortOrder="20" formElement="input">
            <settings>
                <label translate="true">Model</label>
                <dataType>text</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="max_text_length" xsi:type="number">100</rule>
                </validation>
            </settings>
        </field>

        <field name="year_start" sortOrder="30" formElement="input">
            <settings>
                <label translate="true">Year Start</label>
                <dataType>number</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="year_end" sortOrder="40" formElement="input">
            <settings>
                <label translate="true">Year End</label>
                <dataType>number</dataType>
                <tooltip>
                    <description translate="true">Leave empty if vehicle is still in production.</description>
                </tooltip>
                <validation>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>

        <field name="submodel" sortOrder="50" formElement="input">
            <settings>
                <label translate="true">Submodel</label>
                <dataType>text</dataType>
                <validation>
                    <rule name="max_text_length" xsi:type="number">100</rule>
                </validation>
            </settings>
        </field>

        <field name="engine" sortOrder="60" formElement="input">
            <settings>
                <label translate="true">Engine</label>
                <dataType>text</dataType>
                <validation>
                    <rule name="max_text_length" xsi:type="number">100</rule>
                </validation>
            </settings>
        </field>

        <field name="is_active" sortOrder="70" formElement="select">
            <settings>
                <label translate="true">Is Active</label>
                <dataType>select</dataType>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
    </fieldset>
</form>
