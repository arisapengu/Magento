<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="vendor_vehicle" resource="default" engine="innodb" comment="Vehicle Table">
        <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="make" nullable="false" length="100" comment="Make"/>
        <column xsi:type="varchar" name="model" nullable="false" length="100" comment="Model"/>
        <column xsi:type="smallint" name="year_start" nullable="false" comment="Year Start"/>
        <column xsi:type="smallint" name="year_end" nullable="true" comment="Year End"/>
        <column xsi:type="varchar" name="submodel" nullable="true" length="100" comment="Submodel"/>
        <column xsi:type="varchar" name="engine" nullable="true" length="100" comment="Engine"/>
        <column xsi:type="smallint" name="is_active" nullable="false" default="1" comment="Is Active"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <index referenceId="VENDOR_VEHICLE_MAKE" indexType="btree">
            <column name="make"/>
        </index>
        <index referenceId="VENDOR_VEHICLE_MODEL" indexType="btree">
            <column name="model"/>
        </index>
    </table>
</schema>
