<?php
/**
 * @var \Vendor\CancelOrder\Block\Order\Cancel $block
 * @var \Magento\Framework\Escaper $escaper
 */
if (!$block->canCancel()) {
    return;
}
$reasons = $block->getCancelReasons();
?>

<button type="button"
        class="action cancel-order-btn"
        id="cancel-order-trigger"
        data-order-id="<?= (int) $block->getOrderId() ?>"
        data-order-number="<?= $escaper->escapeHtmlAttr($block->getOrderNumber()) ?>">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">
        <circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>
    </svg>
    <span><?= $escaper->escapeHtml(__('Cancel Order')) ?></span>
</button>

<!-- Cancel Modal -->
<div id="cancel-order-modal" class="cancel-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="cancel-modal-title">
    <div class="cancel-modal">

        <div class="cancel-modal__header">
            <h3 id="cancel-modal-title" class="cancel-modal__title"><?= $escaper->escapeHtml(__('Cancel Order')) ?></h3>
            <button type="button" class="cancel-modal__close" id="cancel-modal-close" aria-label="<?= $escaper->escapeHtmlAttr(__('Close')) ?>">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>

        <div class="cancel-modal__body">
            <div class="cancel-modal__warning">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                <p><?= $escaper->escapeHtml(__('Are you sure you want to cancel order #')) ?>
                   <strong id="cancel-modal-order-number"></strong>?
                   <?= $escaper->escapeHtml(__('This action cannot be undone.')) ?>
                </p>
            </div>

            <?php if (!empty($reasons)): ?>
            <div class="cancel-modal__field">
                <label class="cancel-modal__label" for="cancel-reason">
                    <?= $escaper->escapeHtml(__('Reason for cancellation')) ?>
                    <span class="cancel-modal__required">*</span>
                </label>
                <select id="cancel-reason" name="reason" class="cancel-modal__select" required>
                    <option value=""><?= $escaper->escapeHtml(__('-- Select a reason --')) ?></option>
                    <?php foreach ($reasons as $reason): ?>
                    <option value="<?= $escaper->escapeHtmlAttr($reason) ?>">
                        <?= $escaper->escapeHtml($reason) ?>
                    </option>
                    <?php endforeach; ?>
                </select>
                <p class="cancel-modal__error" id="cancel-reason-error" style="display:none">
                    <?= $escaper->escapeHtml(__('Please select a reason.')) ?>
                </p>
            </div>
            <?php endif; ?>

            <div class="cancel-modal__message" id="cancel-modal-message" style="display:none"></div>
        </div>

        <div class="cancel-modal__footer">
            <button type="button" class="cancel-modal__btn cancel-modal__btn--secondary" id="cancel-modal-dismiss">
                <?= $escaper->escapeHtml(__('Keep Order')) ?>
            </button>
            <button type="button" class="cancel-modal__btn cancel-modal__btn--danger" id="cancel-modal-confirm">
                <span class="cancel-modal__btn-text"><?= $escaper->escapeHtml(__('Yes, Cancel Order')) ?></span>
                <span class="cancel-modal__spinner" style="display:none">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="spin">
                        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4"/>
                    </svg>
                    <?= $escaper->escapeHtml(__('Cancelling...')) ?>
                </span>
            </button>
        </div>
    </div>
</div>

<script>
require(['Vendor_CancelOrder/js/cancel-order'], function (cancelOrder) {
    cancelOrder.init({
        cancelUrl: '<?= $escaper->escapeJs($block->getCancelUrl()) ?>',
        hasReasons: <?= !empty($reasons) ? 'true' : 'false' ?>
    });
});
</script>
