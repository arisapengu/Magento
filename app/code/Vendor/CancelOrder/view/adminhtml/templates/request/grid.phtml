<style>
.cancel-requests-grid { padding: 20px; }
.action-approve { background: #007bdb; color: #fff; border: none; padding: 6px 14px; border-radius: 4px; cursor: pointer; margin-right: 4px; }
.action-reject  { background: #d9534f; color: #fff; border: none; padding: 6px 14px; border-radius: 4px; cursor: pointer; }
.action-approve:hover { background: #0060b0; }
.action-reject:hover  { background: #c9302c; }
.action-group { display: flex; align-items: center; flex-wrap: wrap; gap: 4px; }
</style>

<script>
require(['jquery'], function ($) {
    $(document).on('click', '.action-approve, .action-reject', function () {
        var $btn       = $(this);
        var $group     = $btn.closest('.action-group');
        var requestId  = $group.data('request-id');
        var url        = $btn.data('url');
        var formKey    = $btn.data('form-key');
        var adminNote  = $group.find('.admin-note-input').val();

        if (!confirm('<?= $block->escapeJs(__('Are you sure?')) ?>')) return;

        $btn.prop('disabled', true).text('...');

        $.post(url, { request_id: requestId, admin_note: adminNote, form_key: formKey }, function (res) {
            if (res.success) {
                $('#request-row-' + requestId).find('.col-actions').html(
                    '<span style="color:#28a745;font-weight:600">' + res.message + '</span>'
                );
                $('#request-row-' + requestId).find('td:nth-child(6)').html(
                    '<span style="font-weight:600">' + (url.indexOf('approve') > -1 ? 'Approved' : 'Rejected') + '</span>'
                );
            } else {
                alert(res.message);
                $btn.prop('disabled', false).text($btn.hasClass('action-approve') ? 'Approve' : 'Reject');
            }
        }, 'json').fail(function () {
            alert('An error occurred.');
            $btn.prop('disabled', false);
        });
    });
});
</script>
