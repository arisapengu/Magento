<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="vendor_attribute_option_image" resource="default" engine="innodb"
           comment="Image per EAV attribute option">
        <column xsi:type="int"     name="id"        unsigned="true" nullable="false" identity="true"/>
        <column xsi:type="int"     name="option_id" unsigned="true" nullable="false" comment="eav_attribute_option.option_id"/>
        <column xsi:type="varchar" name="image"     nullable="true" length="255"     comment="Media-relative path"/>
        <constraint xsi:type="primary"  referenceId="PRIMARY"><column name="id"/></constraint>
        <constraint xsi:type="unique"   referenceId="VENDOR_ATTR_OPT_IMG_OPTION_ID"><column name="option_id"/></constraint>
        <constraint xsi:type="foreign"
                    referenceId="VENDOR_ATTR_OPT_IMG_FK_OPTION"
                    table="vendor_attribute_option_image" column="option_id"
                    referenceTable="eav_attribute_option" referenceColumn="option_id"
                    onDelete="CASCADE"/>
    </table>
</schema>
