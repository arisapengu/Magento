<script>
require(['chartjs'], function (Chart) {
(function () {
    const labels  = <?= /* @noEscape */ $labelsJson ?>;
    const amounts = <?= /* @noEscape */ $amountsJson ?>;
    const currentMonth = new Date().getMonth();

    const backgroundColors = amounts.map((_, i) =>
        i === currentMonth ? 'rgba(215,38,56,0.95)' : 'rgba(215,38,56,0.35)'
    );
    const borderColors = amounts.map((_, i) =>
        i === currentMonth ? '#ff4d6d' : 'rgba(215,38,56,0.6)'
    );

    const ctx = document.getElementById('widgetOrderChart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels,
            datasets: [{
                label: 'Amount (THB)',
                data: amounts,
                backgroundColor: backgroundColors,
                borderColor: borderColors,
                borderWidth: 2,
                borderRadius: 5,
                borderSkipped: false,
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#003366',
                    borderColor: '#ccd6e0',
                    borderWidth: 1,
                    titleColor: '#ffffff',
                    bodyColor: '#a0b8cc',
                    callbacks: {
                        label: ctx => ' ฿' + ctx.parsed.y.toLocaleString('th-TH', {minimumFractionDigits: 2})
                    }
                }
            },
            scales: {
                x: {
                    ticks: { color: '#5a7a99', font: { family: 'Sora', size: 10 } },
                    grid: { color: 'rgba(0,51,102,0.06)' }
                },
                y: {
                    ticks: {
                        color: '#5a7a99',
                        font: { family: 'Space Mono', size: 10 },
                        callback: v => '฿' + v.toLocaleString()
                    },
                    grid: { color: 'rgba(0,51,102,0.08)' }
                }
            }
        }
    });
})();
});
</script>
