<script>
require(['chartjs'], function (Chart) {
(function () {
    const labels  = <?= /* @noEscape */ $labelsJson ?>;
    const amounts = <?= /* @noEscape */ $amountsJson ?>;
    const currentMonth = new Date().getMonth(); // 0-indexed

    const backgroundColors = amounts.map((_, i) =>
        i === currentMonth ? 'rgba(215,38,56,0.95)' : 'rgba(215,38,56,0.35)'
    );
    const borderColors = amounts.map((_, i) =>
        i === currentMonth ? '#ff4d6d' : 'rgba(215,38,56,0.6)'
    );

    const ctx = document.getElementById('orderChart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels,
            datasets: [{
                label: 'Amount (THB)',
                data: amounts,
                backgroundColor: backgroundColors,
                borderColor: borderColors,
                borderWidth: 2,
                borderRadius: 6,
                borderSkipped: false,
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    backgroundColor: '#22262f',
                    borderColor: '#2e3340',
                    borderWidth: 1,
                    titleColor: '#e8eaf0',
                    bodyColor: '#7a8099',
                    callbacks: {
                        label: ctx => ' ฿' + ctx.parsed.y.toLocaleString('th-TH', {minimumFractionDigits: 2})
                    }
                }
            },
            scales: {
                x: {
                    ticks: { color: '#7a8099', font: { family: 'Sora', size: 11 } },
                    grid: { color: 'rgba(255,255,255,0.04)' }
                },
                y: {
                    ticks: {
                        color: '#7a8099',
                        font: { family: 'Space Mono', size: 10 },
                        callback: v => '฿' + v.toLocaleString()
                    },
                    grid: { color: 'rgba(255,255,255,0.06)' }
                }
            }
        }
    });
})();
});
</script>
